{
  "name": "studynotion-root",
  "version": "1.0.0",
  "description": "StudyNotion MERN Application",
  "scripts": {
    "install:all": "npm install --prefix frontend && npm install --prefix server",
    "dev:frontend": "npm start --prefix frontend",
    "dev:server": "npm run dev --prefix server",
    "dev": "concurrently -n \"frontend,server\" -c \"bgBlue,bgYellow\" \"npm run dev:frontend\" \"npm run dev:server\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
